#!/usr/bin/env bash
# modelrelay-llamafile — Download, run, and relay llamafile models via ModelRelay
# https://github.com/ericflo/modelrelay
#
# Usage:
#   modelrelay-llamafile list [filter] [--tag TAG]  List available models
#   modelrelay-llamafile recommend                   Suggest models for your hardware
#   modelrelay-llamafile download <model>            Download a model
#   modelrelay-llamafile run <model> [options]       Run a model locally
#   modelrelay-llamafile serve <model> [options]     Run + connect to ModelRelay
#   modelrelay-llamafile test <model>                Send a test prompt
#   modelrelay-llamafile status                      Show running models
#   modelrelay-llamafile stop [model|all]            Stop running model(s)
#   modelrelay-llamafile restart <model>             Restart a running model
#   modelrelay-llamafile logs <model> [-f]           View model logs
#   modelrelay-llamafile import <path> [--slug NAME] Register a custom llamafile
#   modelrelay-llamafile rm <model>                  Delete downloaded model
#   modelrelay-llamafile update-catalog              Refresh model catalog from Mozilla
#   modelrelay-llamafile config [set|get|unset|list]  Manage saved settings
#   modelrelay-llamafile doctor                      Check system readiness
#
# Environment:
#   MODELRELAY_HOME     Base directory (default: ~/.modelrelay)
#   PROXY_URL           ModelRelay proxy URL (for 'serve', overrides config)
#   WORKER_SECRET       ModelRelay shared secret (for 'serve', overrides config)
#   LLAMAFILE_PORT      Override default port (default: auto-assigned from 8200)

set -euo pipefail

