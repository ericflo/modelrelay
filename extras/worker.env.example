# /etc/llm-worker-proxy/worker.env — worker-daemon configuration
#
# Copy this file per worker instance and edit the values.
# When using the template unit (worker-daemon@.service), name the file
# worker-<instance>.env  (e.g. worker-gpu0.env, worker-gpu1.env).

# Base URL of the proxy server the worker connects to.
PROXY_URL=http://127.0.0.1:8080

# Shared secret — must match the proxy's WORKER_SECRET.
WORKER_SECRET=changeme

# URL of the local model backend (llama-server, Ollama, vLLM, etc.).
BACKEND_URL=http://127.0.0.1:8000

# Comma-separated list of model names this worker serves.
MODELS=llama3.2:3b

# Human-readable name for this worker instance.
# When using the systemd template unit this is set automatically via %i,
# but you can override it here.
# WORKER_NAME=gpu0

# Provider name to register with on the proxy.
# PROVIDER_NAME=local

# Maximum concurrent requests this worker handles.
# MAX_CONCURRENCY=1

# Log level.  Examples: info, debug, worker_daemon=debug
# Overridden by RUST_LOG if set.
# LOG_LEVEL=info
