# docker-compose environment variables
#
# Copy to .env and edit:  cp .env.example .env

# REQUIRED — shared secret between proxy and all workers.
# Generate one:  openssl rand -hex 32
WORKER_SECRET=changeme

# Host port the proxy is published on.
LISTEN_PORT=8080

# Proxy tuning (defaults are usually fine).
# MAX_QUEUE_LEN=100
# QUEUE_TIMEOUT_SECS=30
# REQUEST_TIMEOUT_SECS=300

# Log levels — set per component.
# PROXY_LOG_LEVEL=info
# WORKER_LOG_LEVEL=info

# ── Worker 1 ────────────────────────────────────────────────────────
# Backend URL for worker1 (e.g. llama-server on the Docker host).
WORKER1_BACKEND_URL=http://host.docker.internal:8000
WORKER1_MODELS=llama3.2:3b
# WORKER1_MAX_CONCURRENCY=1

# ── Worker 2 ────────────────────────────────────────────────────────
WORKER2_BACKEND_URL=http://host.docker.internal:8001
WORKER2_MODELS=codellama:7b
# WORKER2_MAX_CONCURRENCY=1
