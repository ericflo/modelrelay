# Copy to secrets.yaml, fill in values, apply with: kubectl apply -f secrets.yaml
# NEVER commit secrets.yaml with real values!
apiVersion: v1
kind: Secret
metadata:
  name: modelrelay-cloud
  namespace: modelrelay
type: Opaque
stringData:
  DATABASE_URL: "postgres://modelrelay:CHANGE_ME@postgres:5432/modelrelay"
  SESSION_SECRET: "CHANGE_ME_32_bytes_minimum_random_string"
  STRIPE_SECRET_KEY: "sk_live_CHANGE_ME"
  STRIPE_WEBHOOK_SECRET: "whsec_CHANGE_ME"
  MODELRELAY_ADMIN_TOKEN: "CHANGE_ME"
  MODELRELAY_ADMIN_URL: "https://api.modelrelay.io"
  WORKER_SECRET: "CHANGE_ME"
  POSTGRES_PASSWORD: "CHANGE_ME"
  # Comma-separated list of admin email addresses. Users matching these emails
  # are granted admin status (dashboard bypass, API key generation/revocation).
  # Grant-only: removing an email does NOT demote existing admins.
  ADMIN_EMAILS: "floguy@gmail.com"
---
# modelrelay-server secret — separate database for the relay server
# Copy to secrets.yaml, fill in values, apply with: kubectl apply -f secrets.yaml
# NEVER commit secrets.yaml with real values!
apiVersion: v1
kind: Secret
metadata:
  name: modelrelay-server
  namespace: modelrelay
type: Opaque
stringData:
  DATABASE_URL: "postgres://modelrelay:CHANGE_ME@postgres:5432/modelrelay_server"
