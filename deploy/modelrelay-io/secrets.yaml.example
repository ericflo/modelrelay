# Copy to secrets.yaml, fill in values, apply with: kubectl apply -f secrets.yaml
# NEVER commit secrets.yaml with real values!
apiVersion: v1
kind: Secret
metadata:
  name: modelrelay-cloud
  namespace: modelrelay
type: Opaque
stringData:
  DATABASE_URL: "postgres://modelrelay:CHANGE_ME@postgres:5432/modelrelay"
  SESSION_SECRET: "CHANGE_ME_32_bytes_minimum_random_string"
  STRIPE_SECRET_KEY: "sk_live_CHANGE_ME"
  STRIPE_WEBHOOK_SECRET: "whsec_CHANGE_ME"
  MODELRELAY_ADMIN_TOKEN: "CHANGE_ME"
  MODELRELAY_ADMIN_URL: "https://api.modelrelay.io"
  WORKER_SECRET: "CHANGE_ME"
  POSTGRES_PASSWORD: "CHANGE_ME"
